# Copy this file to .env and fill in your values
PORT=3001
JWT_SECRET=generate_a_strong_random_secret_here
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
DB_CONNECTION=Driver={SQL Server};Server=YOUR_SERVER\SQLEXPRESS;Database=QrAppDb;Trusted_Connection=yes;

# Subscriptions / billing
# Which billing backend to use: 'mock' (default, no real payments) | 'payhere' (later)
BILLING_PROVIDER=mock

# Image uploads (Cloudinary) — REQUIRED for logo / welcome / login / banner uploads.
# Without these, POST /api/upload returns 500 and every image upload fails.
# Get them from your Cloudinary dashboard (or copy from the production env).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
